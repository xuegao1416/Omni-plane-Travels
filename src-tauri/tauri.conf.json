{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "世界漫游指南",
  "version": "2.2.0",
  "identifier": "com.omni-plane-travels.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "世界漫游指南",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/xuegao1416/Omni-plane-Travels/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEJEMjg5RjExQ0FDOTg1NjAKUldSZ2hjbktFWjhvdlJQN3BLWVVReC80cU1XVXBNNmYvMGErbTNvalFpOHlGZE00RldCK2M0OXoK"
    }
  }
}
